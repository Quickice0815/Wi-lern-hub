# Supabase-Projekt (Settings → API im Supabase-Dashboard).
# Für lokale Entwicklung: Datei nach .env.local kopieren und Werte eintragen.
# Der anon-Key ist öffentlich vorgesehen (kein Geheimnis) — er darf im
# Frontend-Bundle landen, die Row-Level-Security-Policies schützen die Daten.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
